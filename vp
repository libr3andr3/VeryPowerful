#!/usr/bin/env python3
"""VeryPowerful CLI — one-command web app deployment.

Usage:
  vp create <domain> <app-type>     Deploy a web app
  vp list                           List deployed apps
  vp remove <domain>                Remove a deployed app
  vp status                         Show deployment status

App types: frappe-lms, static, docker-generic
"""

import json
import os
import subprocess
import sys
from pathlib import Path

# ── Config (override via env vars) ──────────────────────────────────
VPS = os.environ.get("VP_VPS", "root@103.89.12.145")
HOME = os.environ.get("VP_HOME", "ssh.campusgenie.ai")
HOME_DEPLOY_DIR = os.environ.get("VP_DEPLOY_DIR", "/opt/yaya")
WG_SUBNET = os.environ.get("VP_WG_SUBNET", "10.0.0.0/24")
HOME_WG_IP = os.environ.get("VP_HOME_WG_IP", "10.0.0.2")
VPS_WG_IP = os.environ.get("VP_VPS_WG_IP", "10.0.0.1")
APPS_DIR = Path(__file__).parent / "apps"

G = '\033[0;32m'; Y = '\033[1;33m'; R = '\033[0;31m'; C = '\033[0;36m'
W = '\033[1m'; N = '\033[0m'

def ok(msg):   print(f"  {G}OK{N}  {msg}")
def warn(msg): print(f"  {Y}!!{N}  {msg}")
def die(msg):  print(f"  {R}ERR{N} {msg}"); sys.exit(1)
def hdr(msg):  print(f"\n{W}{C}=== {msg} ==={N}\n")


def ssh(host, cmd, check=True):
    """Run a command on a remote host via SSH."""
    result = subprocess.run(
        ["ssh", host, cmd],
        capture_output=True, text=True, timeout=120
    )
    if check and result.returncode != 0:
        die(f"SSH {host}: {result.stderr.strip()}")
    return result


def add_sni_route(domain):
    """Add SNI route on VPS: domain → HOME_WG_IP:443."""
    print(f"  Adding SNI route: {domain} → {HOME_WG_IP}:443")
    # Check if already exists
    r = ssh(VPS, f"grep -q '{domain}' /etc/nginx/stream-sni-map.conf", check=False)
    if r.returncode == 0:
        ok(f"SNI route already exists for {domain}")
        return
    # Insert before the default line
    ssh(VPS, f"sed -i '/^default/i {domain} {HOME_WG_IP}:443;' /etc/nginx/stream-sni-map.conf")
    ssh(VPS, "nginx -t && nginx -s reload")
    ok(f"SNI route added: {domain} → {HOME_WG_IP}:443")


def add_caddy_block(domain, port=None, static_dir=None):
    """Add a Caddy block for the domain on the home server."""
    caddyfile = f"{HOME_DEPLOY_DIR}/Caddyfile"
    print(f"  Adding Caddy block for {domain}")

    # Check if already exists
    r = ssh(HOME, f"grep -q '{domain}' {caddyfile}", check=False)
    if r.returncode == 0:
        ok(f"Caddy block already exists for {domain}")
        return

    if static_dir:
        block = f"""
{domain} {{
    bind {HOME_WG_IP}
    root * {static_dir}
    encode gzip
    header Cache-Control "public, max-age=3600"
    @notStatic {{
        not file
        not path_regexp \\\\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|wasm|json|map)$
    }}
    rewrite @notStatic /index.html
    file_server
}}
"""
    elif port:
        block = f"""
{domain} {{
    bind {HOME_WG_IP}
    reverse_proxy 127.0.0.1:{port}
}}
"""
    else:
        die("Must provide port= or static_dir= for Caddy block")

    # Append to Caddyfile
    ssh(HOME, f"cat >> {caddyfile} << 'VPEOF'\n{block}VPEOF")
    ok(f"Caddy block added for {domain}")


def reload_caddy():
    """Reload Caddy to pick up new config."""
    print("  Reloading Caddy...")
    r = ssh(HOME, f"cd {HOME_DEPLOY_DIR} && docker compose restart caddy", check=False)
    if r.returncode == 0:
        ok("Caddy reloaded")
    else:
        warn(f"Caddy reload warning: {r.stderr.strip()}")


def deploy_docker_compose(app_type, domain, compose_content):
    """Write a docker-compose file and start the services."""
    app_dir = f"{HOME_DEPLOY_DIR}/apps/{domain.replace('.', '_')}"
    compose_path = f"{app_dir}/docker-compose.yml"

    print(f"  Deploying {app_type} to {app_dir}")

    # Create directory and write compose file
    ssh(HOME, f"mkdir -p {app_dir}")

    # Write compose via heredoc
    ssh(HOME, f"cat > {compose_path} << 'VPEOF'\n{compose_content}VPEOF")

    # Start containers
    ssh(HOME, f"cd {app_dir} && docker compose up -d", check=False)
    ok(f"{app_type} containers started at {app_dir}")


def cmd_create(domain, app_type):
    """Deploy a new web app."""
    app_dir = APPS_DIR / app_type
    if not app_dir.is_dir():
        die(f"Unknown app type: {app_type}\n  Available: {', '.join(sorted(d.name for d in APPS_DIR.iterdir() if d.is_dir()))}")

    manifest_path = app_dir / "manifest.json"
    compose_path = app_dir / "docker-compose.yml"

    if not manifest_path.is_file():
        die(f"No manifest.json found in apps/{app_type}/")

    with open(manifest_path) as f:
        manifest = json.load(f)

    print(f"{W}Deploying {app_type} at {domain}{N}")
    print(f"  Type: {manifest.get('description', app_type)}")

    # 1. Add VPS SNI route
    hdr("VPS SNI route")
    add_sni_route(domain)

    # 2. Add Caddy routing
    hdr("Caddy routing")
    deploy_type = manifest.get("deploy_type", "docker")

    if deploy_type == "static":
        static_dir = manifest.get("static_dir", f"/srv/www/{domain.replace('.', '_')}")
        add_caddy_block(domain, static_dir=static_dir)
        # For static, also download/extract if url provided
        if manifest.get("static_url"):
            download_static(domain, manifest)
        reload_caddy()
    elif deploy_type == "docker":
        port = manifest.get("port")
        if not port:
            die("manifest.json must specify 'port' for docker deploy_type")
        add_caddy_block(domain, port=port)

        # 3. Generate docker-compose from template
        hdr("Docker Compose")
        if not compose_path.is_file():
            die(f"No docker-compose.yml found in apps/{app_type}/")

        compose_raw = compose_path.read_text()

        # Variable substitution (supports both {{X}} and __X__ formats)
        compose_content = compose_raw.replace("{{DOMAIN}}", domain).replace("__DOMAIN__", domain)
        compose_content = compose_content.replace("{{APP_NAME}}", domain.replace('.', '_')).replace("__APP_NAME__", domain.replace('.', '_'))
        compose_content = compose_content.replace("{{PORT}}", str(port)).replace("__PORT__", str(port))

        # Generate secrets
        import secrets
        db_password = secrets.token_urlsafe(16)
        admin_password = secrets.token_urlsafe(12)
        compose_content = compose_content.replace("{{DB_PASSWORD}}", db_password).replace("__DB_PASSWORD__", db_password)
        compose_content = compose_content.replace("{{ADMIN_PASSWORD}}", admin_password).replace("__ADMIN_PASSWORD__", admin_password)

        # Jitsi shared secrets (all containers need same value)
        jitsi_secret = secrets.token_urlsafe(24)
        compose_content = compose_content.replace("{{JITSI_SECRET}}", jitsi_secret).replace("__JITSI_SECRET__", jitsi_secret)

        deploy_docker_compose(app_type, domain, compose_content)

        # 4. Run post-deploy init if exists
        init_path = app_dir / "init.sh"
        if init_path.is_file():
            hdr("Post-deploy init")
            run_init(app_type, domain, init_path.read_text(), admin_password)

        # 5. Reload Caddy
        hdr("Caddy reload")
        reload_caddy()
    else:
        die(f"Unknown deploy_type: {deploy_type}")

    # Done
    print(f"\n  {G}{W}Deployed!{N}")
    print(f"  URL:  https://{domain}/")
    if manifest.get("notes"):
        print(f"  {manifest['notes']}")


def download_static(domain, manifest):
    """Download and extract a static site."""
    static_url = manifest["static_url"]
    target = f"{HOME_DEPLOY_DIR}/www/{domain}"
    print(f"  Downloading static assets for {domain}...")
    ssh(HOME, f"mkdir -p {target}")
    ssh(HOME, f"curl -fsSL '{static_url}' | tar xz --strip-components=1 -C {target}")


def run_init(app_type, domain, init_script, admin_password):
    """Run post-deploy initialization inside the container."""
    container = f"{domain.replace('.', '_')}_app_1"
    # Wait for container to be ready
    import time
    print(f"  Waiting for {container} to be ready...")
    for _ in range(30):
        r = ssh(HOME, f"docker ps --filter name={container} --format '{{{{.Status}}}}'", check=False)
        if "Up" in r.stdout:
            break
        time.sleep(2)
    else:
        warn("Container may not be ready yet")

    # Run init script
    # Escape the script for heredoc
    ssh(HOME, f"docker exec {container} bash -c '{init_script}'", check=False)


def cmd_list():
    """List deployed apps."""
    r = ssh(HOME, f"ls {HOME_DEPLOY_DIR}/apps/ 2>/dev/null || echo '(none)'", check=False)
    print(f"\n{W}Deployed apps:{N}")
    for d in sorted(r.stdout.strip().split()):
        if d != "(none)":
            domain = d.replace('_', '.')
            # Check container status
            r2 = ssh(HOME, f"docker ps --filter name={d} --format '{{{{.Status}}}}' 2>/dev/null || echo 'unknown'", check=False)
            status = r2.stdout.strip() or "unknown"
            print(f"  {C}{domain}{N}  ({status})")


def cmd_remove(domain):
    """Remove a deployed app."""
    app_name = domain.replace('.', '_')
    app_dir = f"{HOME_DEPLOY_DIR}/apps/{app_name}"

    print(f"{Y}Removing {domain}...{N}")

    # Stop and remove containers
    r = ssh(HOME, f"cd {app_dir} && docker compose down -v 2>/dev/null || true", check=False)

    # Remove app directory
    ssh(HOME, f"rm -rf {app_dir}")

    # Remove Caddy block (between domain line and next closing brace)
    ssh(HOME, f"sed -i '/^{domain} /,/^}}$/d' {HOME_DEPLOY_DIR}/Caddyfile")

    # Remove SNI route from VPS
    ssh(VPS, f"sed -i '/^{domain} /d' /etc/nginx/stream-sni-map.conf")
    ssh(VPS, "nginx -t && nginx -s reload")

    reload_caddy()
    ok(f"Removed {domain}")


def cmd_status():
    """Show deployment status."""
    hdr("VeryPowerful Status")
    print(f"  VPS:      {VPS}")
    print(f"  Home:     {HOME}")
    print(f"  WG hub:   {VPS_WG_IP}")
    print(f"  WG spoke: {HOME_WG_IP}")

    # Check WG tunnel
    r = ssh(HOME, "wg show wg0 2>/dev/null | grep -E 'handshake|transfer' || echo 'tunnel down'", check=False)
    print(f"  Tunnel:   {r.stdout.strip()}")

    # Check SNI routes
    r = ssh(VPS, "grep -v '^#' /etc/nginx/stream-sni-map.conf | grep -v '^$' | grep -v default", check=False)
    print(f"\n  {W}SNI routes:{N}")
    for line in r.stdout.strip().split('\n'):
        if line.strip():
            print(f"    {line.strip()}")

    # Check Caddy domains
    r = ssh(HOME, f"grep -E '^[a-z].*\\.yaya\\.sh' {HOME_DEPLOY_DIR}/Caddyfile", check=False)
    print(f"\n  {W}Caddy domains:{N}")
    for line in r.stdout.strip().split('\n'):
        if line.strip():
            print(f"    {line.strip()}")


# ── Main ────────────────────────────────────────────────────────────
def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    cmd = sys.argv[1]

    if cmd == "create":
        if len(sys.argv) != 4:
            die("Usage: vp create <domain> <app-type>")
        cmd_create(sys.argv[2], sys.argv[3])
    elif cmd == "list":
        cmd_list()
    elif cmd == "remove":
        if len(sys.argv) != 3:
            die("Usage: vp remove <domain>")
        cmd_remove(sys.argv[2])
    elif cmd == "status":
        cmd_status()
    else:
        die(f"Unknown command: {cmd}\n  Commands: create, list, remove, status")


if __name__ == "__main__":
    main()
